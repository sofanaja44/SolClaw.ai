# ═══════════════════════════════════════
# 🐾 SOLCLAW.AI — Configuration
# ═══════════════════════════════════════
# Copy this to .env and fill in your values

# === Trading Mode ===
PAPER_TRADING=true
PAPER_BALANCE_USD=100

# === Jupiter API ===
JUP_API_BASE=https://api.jup.ag
JUP_API_KEY=your_jupiter_api_key

# === OpenRouter AI ===
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# === Wallet (not needed for paper trading) ===
WALLET_PRIVATE_KEY=not_needed_for_paper_mode

# === Solana RPC ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# === Risk Management ===
POSITION_SIZE_PCT=1
MIN_RISK_REWARD_RATIO=2.0
MAX_DAILY_LOSS_PCT=5
MAX_PRICE_IMPACT_PCT=3.0
DEFAULT_SLIPPAGE_BPS=150
TRADE_COOLDOWN_MS=10000

# === Scanner Config ===
SCAN_INTERVAL_MS=10000
MONITOR_INTERVAL_MS=5000
MAX_TOKENS_WATCH=50
MIN_LIQUIDITY_USD=5000
MIN_VOLUME_24H_USD=20000

# ═══════════════════════════════════════
# PHASE 1: SPEED & EXECUTION
# ═══════════════════════════════════════
DYNAMIC_FEES_ENABLED=true
MAX_PRIORITY_FEE_LAMPORTS=5000000

# Jito MEV Protection (live trading only)
JITO_ENABLED=false
JITO_TIP_LAMPORTS=10000

# ═══════════════════════════════════════
# PHASE 2: DATA & RELIABILITY
# ═══════════════════════════════════════

# Telegram Alert Bot
# Setup: Chat @BotFather -> /newbot -> get token
# Then: https://api.telegram.org/bot<TOKEN>/getUpdates -> get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════
# PHASE 3: SMART TRAILING STOP-LOSS
# ═══════════════════════════════════════
TRAILING_SL_ENABLED=true
TRAILING_SL_ACTIVATION_PCT=3
TRAILING_SL_DISTANCE_PCT=5
BREAKEVEN_LOCK_PCT=2

# ═══════════════════════════════════════
# PHASE 4: PARTIAL TAKE-PROFIT (SCALING OUT)
# ═══════════════════════════════════════
# Sell portions of position at different profit levels
PARTIAL_TP_ENABLED=true
# Stage 1: Sell 50% of position when profit hits +50%
PARTIAL_TP_1_PCT=50
PARTIAL_TP_1_SELL=50
# Stage 2: Sell 50% of REMAINING when profit hits +100%
PARTIAL_TP_2_PCT=100
PARTIAL_TP_2_SELL=50
# The leftover "moonbag" rides with trailing SL only

# ═══════════════════════════════════════
# PHASE 4: WHALE COPY TRADING
# ═══════════════════════════════════════
# Enable to copy trades from smart money wallets
WHALE_TRACKING_ENABLED=false
# Comma-separated Solana wallet addresses to monitor
WHALE_WALLETS=
# How often to check whale wallets (ms)
WHALE_POLL_INTERVAL_MS=30000
